# Google Gemini (Generative Language API) — used by /api/idea
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Google Ads API — used by /api/keywords for search volume + top-of-page CPC bid range
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-oauth-refresh-token
GOOGLE_ADS_MANAGER_ID=manager-customer-id-no-dashes
GOOGLE_ADS_CUSTOMER_ID=customer-id-no-dashes

# DataForSEO — legacy fallback (no longer used by default)
DATAFORSEO_LOGIN=you@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
