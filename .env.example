# Google Gemini (Generative Language API) — used by /api/idea
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# DataForSEO — used by /api/keywords (HTTP Basic auth: login + password)
# Find/verify these at https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=you@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
